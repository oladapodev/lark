{
  "name": "lark-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "hugo server -D",
    "build": "hugo",
    "css": "npx @tailwindcss/cli -i src/main.css -o static/main.css --watch",
